{
  "name": "anigodb",
  "version": "0.1.3",
  "description": "A document database library wrapping better-sqlite3-multiple-ciphers with a MongoDB-style API",
  "type": "module",
  "main": "./dist/cjs/index.js",
  "types": "./dist/esm/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/esm/index.d.ts",
        "default": "./dist/esm/index.js"
      },
      "require": {
        "types": "./dist/cjs/index.d.ts",
        "default": "./dist/cjs/index.js"
      }
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc && tsc --project tsconfig.cjs.json",
    "prepublishOnly": "npm run build && npm test",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/anigodb/anigodb.git"
  },
  "homepage": "https://github.com/anigodb/anigodb",
  "bugs": {
    "url": "https://github.com/anigodb/anigodb/issues"
  },
  "keywords": [
    "database",
    "document-database",
    "sqlite",
    "better-sqlite3",
    "mongodb",
    "embedding",
    "rag",
    "vector-search",
    "fts5",
    "hybrid-search",
    "encryption",
    "nosql",
    "anigodb",
    "anigo"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "better-sqlite3-multiple-ciphers": "^12.10.0",
    "hf-embedder": "^0.2.1",
    "sqlite-hybrid": "^0.1.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "typescript": "^5.8.3",
    "vitest": "^4.1.8"
  },
  "license": "MIT",
  "allowScripts": {
    "better-sqlite3-multiple-ciphers@12.10.0": true,
    "better-sqlite3@12.11.1": true
  }
}
